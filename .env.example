# Copy to .env and fill in. .env is git-ignored.
# On GitHub Actions these are provided as repository secrets instead of a .env file.

# Required: Raindrop.io "test token" (Settings -> Integrations -> create app -> test token)
RAINDROP_TOKEN=

# Target collection (created automatically if it does not exist)
COLLECTION_NAME=starred-repos

# Configure at least one source. A source is enabled only when its token is set.

# GitHub personal access token (read-only; needs the "starring" read scope for private stars).
# NB: do not name this GITHUB_TOKEN on Actions -- that name is reserved by the runner.
GITHUB_STAR_TOKEN=

# GitLab personal access token with the read_api scope.
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com

# Codeberg (Forgejo) access token with read:repository scope.
CODEBERG_TOKEN=
CODEBERG_URL=https://codeberg.org
